<Window x:Class="CudaSpirit.App.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cuda Spirit Overlay"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" Left="0" Top="0" Width="1280" Height="720"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="Grayscale"
        TextElement.Foreground="{DynamicResource InkBrush}">
    <Window.Resources>
        <!-- Thin, semi-transparent scrollbar for overlay panels -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Visibility="Collapsed"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="2" Background="#66FF6A3D"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Visibility="Collapsed"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- ============================================================ -->
        <!-- HUD Stats Panel (top-left) - the existing live stats         -->
        <!-- ============================================================ -->
        <Border x:Name="HudPanel" VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="14,14,0,0" Width="224" Background="#E60D0F12"
                BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" CornerRadius="4"
                Cursor="SizeAll">
            <Border.RenderTransform><TranslateTransform x:Name="HudTransform"/></Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="3" Opacity="0.42"/>
            </Border.Effect>
            <StackPanel>
                <!-- Top accent strip -->
                <Border Height="2" Background="{DynamicResource CrimsonBrush}"/>

                <StackPanel Margin="13,10,13,12">
                    <!-- Header -->
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="22" Height="22" CornerRadius="4" Margin="0,0,8,0"
                                Background="#33E01E37" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1">
                            <Grid Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  RenderOptions.EdgeMode="Unspecified">
                                <Border Width="10" Height="10" BorderBrush="{DynamicResource CrimsonBrush}" BorderThickness="1.35"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform>
                                </Border>
                                <Border Width="4" Height="4" Background="{DynamicResource EmberBrush}"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CUDA SPIRIT" FontWeight="Bold" FontSize="10.5" Foreground="{DynamicResource InkBrush}"/>
                            <TextBlock Text="LIVE HUD" FontSize="7.5" Foreground="{DynamicResource InkSoftBrush}" FontWeight="SemiBold" Margin="0,-1,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- gradient divider -->
                    <Border Height="1" Margin="0,9,0,9" Background="{DynamicResource BorderSubtleBrush}"/>

                    <!-- Silver/hr + Trash -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="5" Height="5" Background="{DynamicResource CrimsonBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SILVER / HR" Foreground="{DynamicResource InkSoftBrush}" FontSize="8.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="SilverHrText" Text="-" Foreground="{DynamicResource EmberBrush}" FontSize="19" FontWeight="Bold" Margin="0,-1,0,0">
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="TRASH" Foreground="{DynamicResource InkSoftBrush}" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="TrashText" Text="0" Foreground="{DynamicResource InkBrush}" FontSize="19" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-1,0,0"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="ZoneText" Text="No active session" Foreground="{DynamicResource InkSoftBrush}" FontSize="9.5"
                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>

                    <!-- gradient divider -->
                    <Border Height="1" Margin="0,10,0,9" Background="{DynamicResource BorderSubtleBrush}"/>

                    <!-- Next boss -->
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Background="{DynamicResource SecondaryWashBrush}" CornerRadius="4" Padding="5,1" Margin="0,0,7,0" VerticalAlignment="Center">
                            <TextBlock Text="BOSS" Foreground="{DynamicResource InkBrush}" FontSize="8" FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="BossText" Text="-" Foreground="{DynamicResource InkBrush}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <!-- Do next - highlighted chip -->
                    <Border Margin="0,8,0,0" CornerRadius="3" Padding="10,8" Background="{DynamicResource BgPanelHiBrush}" BorderBrush="{DynamicResource CrimsonBrush}" BorderThickness="2,1,1,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <Viewbox Width="10" Height="10" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Path Data="M1,1 L6,5 L1,9 M6,5 L0,5" Stroke="{DynamicResource EmberBrush}" StrokeThickness="1.5"
                                          StrokeStartLineCap="Square" StrokeEndLineCap="Square" StrokeLineJoin="Miter"/>
                                </Viewbox>
                                <TextBlock Text="DO NEXT" Foreground="{DynamicResource EmberBrush}" FontSize="8" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="NextStepText" Text="-" Foreground="{DynamicResource InkBrush}" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Scan feedback toast (top center)                             -->
        <!-- ============================================================ -->
        <Border x:Name="Toast" Visibility="Collapsed" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,10,0,0" Background="#F00D0F12" BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12,6">
            <TextBlock x:Name="ToastText" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource InkBrush}"/>
        </Border>

        <!-- ============================================================ -->
        <!-- Interactive mode banner (shown when F7 toggles mouse-on)     -->
        <!-- ============================================================ -->
        <Border x:Name="InteractiveBanner" Visibility="Collapsed" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,8,0,0" Background="{DynamicResource AccentWashBrush}" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1"
                CornerRadius="4" Padding="14,6" Cursor="SizeAll">
            <Border.RenderTransform><TranslateTransform x:Name="BannerTransform"/></Border.RenderTransform>
            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource CrimsonBrush}" VerticalAlignment="Center"
                       Text="HUD INTERACTIVE  /  drag panels  /  F7 returns to click-through"/>
        </Border>

        <!-- ============================================================ -->
        <!-- Status chip (bottom-left, shows hotkeys)                     -->
        <!-- ============================================================ -->
        <Border x:Name="StatusChip" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="14,0,0,14"
                Background="#E60D0F12" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10,5" Cursor="SizeAll">
            <Border.RenderTransform><TranslateTransform x:Name="ChipTransform"/></Border.RenderTransform>
            <TextBlock x:Name="ChipText" Text="F6 lock · F7 HUD · F9 hide · F11 analyze"
                       FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource CrimsonBrush}"/>
        </Border>
    </Grid>
</Window>