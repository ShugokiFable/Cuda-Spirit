<Window x:Class="CudaSpirit.App.Overlay.TasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:CudaSpirit.App.Views"
        Title="Cuda Spirit - Advisor"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        Width="360" Height="620" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="Grayscale">

    <Border CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource BorderStrongBrush}" Background="#F20A090E">
        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="5" Opacity="0.45"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="{DynamicResource AccentGradientBrush}" CornerRadius="4,4,0,0"/>

            <Border x:Name="HeaderBar" Grid.Row="1" Cursor="SizeAll" MouseLeftButtonDown="OnHeaderDrag" Padding="14,12,10,12" Background="#72000000" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="4" Background="{DynamicResource AccentWashBrush}" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" Margin="0,0,11,0">
                        <Grid><Border Width="8" Height="8" Background="{DynamicResource EmberBrush}" RenderTransformOrigin="0.5,0.5"><Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform></Border><Border Width="20" Height="20" BorderBrush="{DynamicResource CrimsonBrush}" BorderThickness="1" RenderTransformOrigin="0.5,0.5"><Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform></Border></Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="AI ADVISOR" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock x:Name="SubtitleText" Text="Synced with the cockpit" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="RefreshBtn" Style="{StaticResource IconButton}" Click="OnRefresh" ToolTip="Ask what should I do next?" Margin="0,0,3,0">
                            <Viewbox Width="15" Height="15">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M13.4,5.8 C12.5,3.5 10.5,2 8,2 C4.7,2 2,4.7 2,8 C2,11.3 4.7,14 8,14 C10.5,14 12.6,12.5 13.5,10.3"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.5" Fill="Transparent" StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
                                    <Path Data="M13.5,2 L13.5,5.8 L9.7,5.8"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.5" Fill="Transparent" StrokeStartLineCap="Square" StrokeEndLineCap="Square" StrokeLineJoin="Miter"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="CloseBtn" Style="{StaticResource IconButton}" Click="OnClose" ToolTip="Close">
                            <Viewbox Width="13" Height="13">
                                <Path Data="M2,2 L14,14 M14,2 L2,14"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      StrokeThickness="1.6" Fill="Transparent" StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="12,10,12,12">
                <v:AdvisorChat/>
            </Grid>
        </Grid>
    </Border>
</Window>
