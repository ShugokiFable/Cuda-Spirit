<UserControl x:Class="CudaSpirit.App.Views.GearView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gear &amp; Progression" Style="{StaticResource H1}" Margin="0,0,0,12"/>

        <!-- Add form -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Add / edit item" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Width="180" Margin="0,0,10,8">
                        <TextBlock Text="Name" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="NameBox"/>
                    </StackPanel>
                    <StackPanel Width="130" Margin="0,0,10,8">
                        <TextBlock Text="Slot" Style="{StaticResource Muted}"/>
                        <ComboBox x:Name="SlotBox"/>
                    </StackPanel>
                    <StackPanel Width="120" Margin="0,0,10,8">
                        <TextBlock Text="Kind" Style="{StaticResource Muted}"/>
                        <ComboBox x:Name="KindBox"/>
                    </StackPanel>
                    <StackPanel Width="110" Margin="0,0,10,8">
                        <TextBlock Text="Grade" Style="{StaticResource Muted}"/>
                        <ComboBox x:Name="GradeBox"/>
                    </StackPanel>
                    <StackPanel Width="70" Margin="0,0,10,8">
                        <TextBlock Text="AP" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="ApBox"/>
                    </StackPanel>
                    <StackPanel Width="70" Margin="0,0,10,8">
                        <TextBlock Text="DP" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="DpBox"/>
                    </StackPanel>
                    <StackPanel Width="80" Margin="0,0,10,8">
                        <TextBlock Text="Caphras" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="CaphrasBox"/>
                    </StackPanel>
                    <CheckBox x:Name="EquippedBox" Content="Equipped" IsChecked="True" VerticalAlignment="Bottom"
                              Foreground="{DynamicResource InkSoftBrush}" Margin="0,0,10,12"/>
                    <Button Style="{StaticResource GlowButton}" Content="Add item" Click="OnAdd" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- List -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Owned gear" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="GearList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPanelHiBrush}" CornerRadius="4" Padding="12,8" Margin="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Slot}" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Display}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ApText}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DpText}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding CaphrasText}" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="5" Content="✕" Tag="{Binding Id}" Click="OnDelete"
                                                Background="Transparent" Foreground="{DynamicResource CrimsonBrush}"
                                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
