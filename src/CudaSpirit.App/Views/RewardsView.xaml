<UserControl x:Class="CudaSpirit.App.Views.RewardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Rewards &amp; Redemption Center" Style="{StaticResource H1}"/>
                <TextBlock Text="A single map for every reward inbox, claim deadline, coupon, event, and pass surface." Style="{StaticResource Muted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource GlowButton}" Content="Sync current rewards" Click="OnSync" VerticalAlignment="Center"/>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="The complete claim sweep" Style="{StaticResource H2}"/>
                        <TextBlock Text="Do this before deciding an item is missing. Check expiration before sending website rewards to a character." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                        <UniformGrid Columns="2">
                            <CheckBox x:Name="WebStorageCheck" Content="Website Web Storage and package/bundle history" Margin="0,5"/>
                            <CheckBox x:Name="MailCheck" Content="In-game Mail (B), including expiration" Margin="0,5"/>
                            <CheckBox x:Name="SafeCheck" Content="Black Spirit's Safe" Margin="0,5"/>
                            <CheckBox x:Name="ChallengeCheck" Content="Challenge rewards (Y)" Margin="0,5"/>
                            <CheckBox x:Name="AttendanceCheck" Content="Attendance / login rewards" Margin="0,5"/>
                            <CheckBox x:Name="EventCheck" Content="Current Event interface and event seals" Margin="0,5"/>
                            <CheckBox x:Name="PassCheck" Content="Season, Black Spirit, combat, and daily passes" Margin="0,5"/>
                            <CheckBox x:Name="GuildCheck" Content="Guild rewards, salary, missions, and boss rewards" Margin="0,5"/>
                            <CheckBox x:Name="CouponCheck" Content="Coupon redemption and redeemed history" Margin="0,5"/>
                            <CheckBox x:Name="PearlCouponCheck" Content="Pearl Shop coupon book and expiring coupons" Margin="0,5"/>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource SubtleButton}" Content="Open coupon guide" Click="OnOpenCouponGuide" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource SubtleButton}" Content="Open mail &amp; safe guide" Click="OnOpenMailGuide" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource SubtleButton}" Content="Reset checks" Click="OnResetChecks" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource GlowButton}" Content="Ask what expires first" Click="OnAskPriority"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,12,16">
                        <StackPanel>
                            <TextBlock Text="Active events &amp; deadlines" Style="{StaticResource H2}"/>
                            <ListBox x:Name="EventsList" Margin="0,10,0,0" MinHeight="260" MouseDoubleClick="OnOpenSelectedEvent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Meta}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="Double-click to open the official source." Style="{StaticResource Muted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Coupons &amp; notices" Style="{StaticResource H2}"/>
                            <ListBox x:Name="CouponsList" Margin="0,10,0,0" MinHeight="260" MouseDoubleClick="OnOpenSelectedCoupon">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Meta}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="Codes can expire, and redeemed rewards can also expire in Web Storage or mail." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock x:Name="StatusText" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
