<UserControl x:Class="CudaSpirit.App.Views.RecoveryCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Returner &amp; Reroll Recovery" Style="{StaticResource H1}"/>
                    <Border Style="{StaticResource WarningPill}" Margin="12,4,0,0" VerticalAlignment="Top">
                        <TextBlock Text="FAIL-CLOSED SAFETY" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Recover an old account, test a new class, and retire characters without losing paid value or irreplaceable progress."
                           Style="{StaticResource Muted}" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource GlowButton}" Content="One-click returner rescue" Click="OnRescueMe" Margin="0,0,9,0"/>
                <Button Style="{StaticResource SubtleButton}" Content="Sync before decisions" Click="OnSync"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Just got back?">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,14,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="4" Background="{DynamicResource AccentWashBrush}" Margin="0,0,14,0">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource EmberBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Start with recovery, not upgrades" Style="{StaticResource H2}"/>
                                    <TextBlock Text="Claim expiring value, quarantine unknown items, refresh your profile, then rebuild progression from verified facts." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Style="{StaticResource SuccessPill}" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="7-DAY SPEND SHIELD READY" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="370"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}" Margin="0,0,12,16">
                                <StackPanel>
                                    <TextBlock Text="Recovery profile" Style="{StaticResource H2}"/>
                                    <TextBlock Text="Tell the planner what is uncertain. It will prioritize reversibility over speed." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                                    <TextBlock Text="Months away" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="MonthsAwayBox" Text="6" Width="105" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Goal for the next week" Style="{StaticResource Muted}" Margin="0,11,0,4"/>
                                    <TextBox x:Name="ReturnerGoalBox" Text="Relearn the game safely" TextWrapping="Wrap"/>
                                    <Separator Margin="0,13,0,10"/>
                                    <CheckBox x:Name="InventoryChaosBox" Content="Inventory and storage are chaotic" IsChecked="True" Margin="0,4"/>
                                    <CheckBox x:Name="GearUnsureBox" Content="I do not trust my old gear plan" IsChecked="True" Margin="0,4"/>
                                    <CheckBox x:Name="MainUnsureBox" Content="I am unsure about my main class" Margin="0,4"/>
                                    <CheckBox x:Name="FreshCharacterBox" Content="I may create or reroll a character" Margin="0,4"/>
                                    <CheckBox x:Name="RewardsBox" Content="I probably have unclaimed rewards" IsChecked="True" Margin="0,4"/>
                                    <CheckBox x:Name="SeasonBox" Content="I already have an active season character" Margin="0,4"/>
                                    <CheckBox x:Name="SpendBox" Content="I am considering Pearl purchases" Margin="0,4"/>
                                    <Button Style="{StaticResource GlowButton}" Content="Build recovery plan" Click="OnBuildReturner" Margin="0,15,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <Button Style="{StaticResource SubtleButton}" Content="Add to Navigator" Click="OnAddReturnerTasks" Margin="0,0,4,0"/>
                                        <Button Grid.Column="1" Style="{StaticResource SubtleButton}" Content="No-spend shield" Click="OnActivateSpendShield" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource ElevatedCard}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="ReturnerHeadline" Text="A safe first session starts with recovery, not upgrades" FontSize="21" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ReturnerSummary" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,13"/>
                                    <DataGrid x:Name="ReturnerGrid" IsReadOnly="True" CanUserAddRows="False" MinHeight="390">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="42"/>
                                            <DataGridTextColumn Header="PHASE" Binding="{Binding Phase}" Width="88"/>
                                            <DataGridTextColumn Header="ACTION" Binding="{Binding Title}" Width="1.05*"/>
                                            <DataGridTextColumn Header="HOW" Binding="{Binding Detail}" Width="2*"/>
                                            <DataGridCheckBoxColumn Header="CRITICAL" Binding="{Binding Critical}" Width="72"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Fresh-character choices" Style="{StaticResource H2}"/>
                                    <TextBlock Text="The safe default is reversible testing before permanent spending." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,22,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="• Prefer the current Season Character path when available.&#x0a;• Use the client’s current recommended beginner route unless you understand alternate-route prerequisites.&#x0a;• A discounted permanent character slot is safer than deleting a developed character for space.&#x0a;• Trial the class, then use Character Tag / Item Copy where eligible before assigning paid weight, inventory, outfits, or coupons.&#x0a;• Sync current official guides and patch notes before committing."
                                           TextWrapping="Wrap" LineHeight="21"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Before deleting a character">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource DangerCard}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="4" Background="{DynamicResource DangerWashBrush}" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1" Margin="0,0,13,0">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="RetirementVerdict" Text="HARD STOP: complete every critical verification before deletion." FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="RetirementProgress" Style="{StaticResource Muted}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Button Style="{StaticResource SubtleButton}" Content="Recalculate" Click="OnRecalculateRetirement" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource DangerButton}" Content="Reset checklist" Click="OnResetRetirement"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid x:Name="RetirementGrid" CanUserAddRows="False" MinHeight="430" CurrentCellChanged="OnRetirementCellChanged" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="DONE" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                                <DataGridCheckBoxColumn Header="CRITICAL" Binding="{Binding Critical}" IsReadOnly="True" Width="68"/>
                                <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" IsReadOnly="True" Width="105"/>
                                <DataGridTextColumn Header="VERIFICATION" Binding="{Binding Title}" IsReadOnly="True" Width="1.05*"/>
                                <DataGridTextColumn Header="WHAT TO PROTECT" Binding="{Binding Detail}" IsReadOnly="True" Width="1.8*"/>
                                <DataGridTextColumn Header="HOW TO CONFIRM" Binding="{Binding Verification}" IsReadOnly="True" Width="1.5*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Row="2" Style="{StaticResource WarningCard}" Padding="13" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource WarningBrush}" Margin="0,1,10,0"/>
                            <TextBlock Text="Cuda Spirit cannot inspect the live game or your account. Green means you manually confirmed every critical row, not that deletion is guaranteed risk-free. Always read the live client’s final warning." TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Which class next?">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,14,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="4" Background="{DynamicResource SecondaryWashBrush}" Margin="0,0,14,0">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="19" Foreground="{DynamicResource PurpleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Pick by friction you enjoy, not a frozen tier list" Style="{StaticResource H2}"/>
                                    <TextBlock Text="The matcher scores control feel and goals. Trial movement, recovery, camera load, and a short rotation before binding permanent value." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="370"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}" Margin="0,0,12,16">
                                <StackPanel>
                                    <TextBlock Text="Play-feel matcher" Style="{StaticResource H2}"/>
                                    <TextBlock Text="Range" Style="{StaticResource Muted}" Margin="0,12,0,4"/><ComboBox x:Name="RangeBox"/>
                                    <TextBlock Text="Pace" Style="{StaticResource Muted}" Margin="0,10,0,4"/><ComboBox x:Name="PaceBox"/>
                                    <TextBlock Text="Complexity" Style="{StaticResource Muted}" Margin="0,10,0,4"/><ComboBox x:Name="ComplexityBox"/>
                                    <TextBlock Text="Survivability" Style="{StaticResource Muted}" Margin="0,10,0,4"/><ComboBox x:Name="SurvivalBox"/>
                                    <TextBlock Text="Primary content" Style="{StaticResource Muted}" Margin="0,10,0,4"/><ComboBox x:Name="FocusBox"/>
                                    <Separator Margin="0,13,0,9"/>
                                    <CheckBox x:Name="SupportBox" Content="I want meaningful support utility" Margin="0,4"/>
                                    <CheckBox x:Name="GrabBox" Content="I specifically want a grab" Margin="0,4"/>
                                    <CheckBox x:Name="LowApmBox" Content="Avoid high-APM classes" Margin="0,4"/>
                                    <Button Style="{StaticResource GlowButton}" Content="Recommend trial classes" Click="OnRecommendClasses" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource ElevatedCard}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Best trial candidates" Style="{StaticResource H2}"/>
                                    <DataGrid x:Name="ClassGrid" IsReadOnly="True" CanUserAddRows="False" MinHeight="420" Margin="0,12,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="CLASS" Binding="{Binding ClassName}" Width="115"/>
                                            <DataGridTextColumn Header="MATCH" Binding="{Binding MatchPercent, StringFormat={}{0}%}" Width="74"/>
                                            <DataGridTextColumn Header="WHY" Binding="{Binding Why}" Width="1.55*"/>
                                            <DataGridTextColumn Header="WATCH OUT" Binding="{Binding WatchOutFor}" Width="1.35*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Border Style="{StaticResource InsetCard}" Padding="12" Margin="0,11,0,0">
                                        <TextBlock Text="Trial rule: test the same short rotation on every candidate. Choose the class whose friction remains enjoyable after the novelty wears off." Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        <TextBlock x:Name="StatusText" Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Style="{StaticResource Caption}" Margin="0,0,14,8" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
