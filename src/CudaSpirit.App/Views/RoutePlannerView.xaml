<UserControl x:Class="CudaSpirit.App.Views.RoutePlannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
            <TextBlock Text="Farm Route Optimizer" Style="{StaticResource H1}"/>
            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,16"
                       Text="Ranks farms and computes travel paths from imported route/grind data. This is a decision engine, not a bot: it never moves your character, sends keys, injects code, or touches anti-cheat."/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="260"/><ColumnDefinition Width="150"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Start" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="StartBox" DisplayMemberPath="Name" Margin="0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Destination" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="3" x:Name="DestinationBox" DisplayMemberPath="Name" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Objective" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ObjectiveBox" Margin="0,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Risk tolerance" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    <Slider Grid.Row="1" Grid.Column="3" x:Name="RiskBox" Minimum="0" Maximum="1" Value="0.5" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Player AP" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="ApBox" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Player DP" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    <TextBox Grid.Row="2" Grid.Column="3" x:Name="DpBox" Margin="0,4"/>

                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Style="{StaticResource GlowButton}" Content="Recommend best farms" Click="OnRecommend" Margin="0,0,8,0"/>
                        <Button Content="Plan selected route" Click="OnPlan"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Recommendations" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                    <ListBox x:Name="RecommendationsList" MinHeight="120" MaxHeight="300">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,5">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Route" Style="{StaticResource H2}"/>
                    <TextBlock x:Name="RouteSummary" Margin="0,8,0,8" TextWrapping="Wrap"/>
                    <ItemsControl x:Name="RouteSteps">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="0,3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
