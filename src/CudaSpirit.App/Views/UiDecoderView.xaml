<UserControl x:Class="CudaSpirit.App.Views.UiDecoderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="In-game UI Decoder" Style="{StaticResource H1}"/>
                <TextBlock Text="Tell it what you are trying to do. It points to the screen, hotkey, hidden restriction, and safer fallback." Style="{StaticResource Muted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource SubtleButton}" Content="Sync official guides" Click="OnSync" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" TextChanged="OnSearch" FontSize="15" Padding="12,8" ToolTip="Examples: redeem coupon, find item, move item, season pass, worker, market warehouse"/>
                <Button Grid.Column="1" Style="{StaticResource GlowButton}" Content="Ask AI with current data" Click="OnAskAi" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Where is that screen?" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="CountText" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="ResultsList" BorderThickness="0" Background="Transparent" SelectionChanged="OnSelected">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPanelHiBrush}" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Category}" Style="{StaticResource Muted}"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Path}" Foreground="{DynamicResource EmberBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Selected workflow" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="SelectedTitle" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,12,0,5"/>
                        <TextBlock x:Name="SelectedPath" Foreground="{DynamicResource EmberBrush}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="SelectedDetail" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        <TextBlock Text="Common blockers" Style="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,14,0,5"/>
                        <ItemsControl x:Name="BlockersList">
                            <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource Muted}"/></TextBlock.Style></TextBlock></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Universal stuck checklist" Style="{StaticResource H2}"/>
                        <TextBlock Text="1. Read the full tooltip and expiry.&#x0a;2. Check character/family binding.&#x0a;3. Unequip it and leave combat/party/mount interfaces.&#x0a;4. Check weight, inventory space, season/class restrictions, cooldowns, and tagged-character rules.&#x0a;5. Use Ctrl+F before buying a duplicate.&#x0a;6. Do not delete or vendor the item as a troubleshooting step." TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="StatusText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
