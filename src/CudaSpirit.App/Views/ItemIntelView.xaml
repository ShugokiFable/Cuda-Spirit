<UserControl x:Class="CudaSpirit.App.Views.ItemIntelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="Item Intel &amp; Transfer Guard" Style="{StaticResource H1}"/>
            <TextBlock Text="Decode unfamiliar loot before an irreversible click, then choose the safest legal transfer path." Style="{StaticResource Muted}" Margin="0,4,0,0"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,12,16">
                        <StackPanel>
                            <TextBlock Text="1. Decode this item" Style="{StaticResource H2}"/>
                            <TextBlock Text="Exact item name" Style="{StaticResource Muted}" Margin="0,12,0,3"/>
                            <TextBox x:Name="ItemNameBox"/>
                            <TextBlock Text="Paste tooltip text (strongly recommended)" Style="{StaticResource Muted}" Margin="0,10,0,3"/>
                            <TextBox x:Name="TooltipBox" Height="115" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Binding shown in tooltip" Style="{StaticResource Muted}"/>
                                    <ComboBox x:Name="BindingBox"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" x:Name="SeasonBox" Content="Current character is seasonal" VerticalAlignment="Bottom" Margin="8,0,0,8"/>
                            </Grid>
                            <Button Style="{StaticResource GlowButton}" Content="Analyze before I touch it" Click="OnAnalyze" Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="VerdictText" Text="No item analyzed" FontSize="19" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ConfidenceText" Style="{StaticResource Muted}" Margin="0,4,0,12"/>
                            <TextBlock Text="Why" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="ExplanationText" TextWrapping="Wrap" Margin="0,5,0,12"/>
                            <TextBlock Text="Where it should live" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="LocationText" TextWrapping="Wrap" Margin="0,5,0,12"/>
                            <TextBlock Text="Binding / transfer warning" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="WarningText" TextWrapping="Wrap" Margin="0,5,0,12"/>
                            <TextBlock Text="Before you act" Style="{StaticResource H2}"/>
                            <ItemsControl x:Name="ChecklistList" Margin="0,5,0,0">
                                <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Margin="0,2"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="2. Move it to another character" Style="{StaticResource H2}"/>
                        <WrapPanel Margin="0,10,0,8">
                            <CheckBox x:Name="MarketableBox" Content="Marketable" Margin="0,0,18,8"/>
                            <CheckBox x:Name="TradeGoodBox" Content="Trade/barter good" Margin="0,0,18,8"/>
                            <CheckBox x:Name="GuildItemBox" Content="Guild item" Margin="0,0,18,8"/>
                            <CheckBox x:Name="TreasureItemBox" Content="Treasure/special item" Margin="0,0,18,8"/>
                            <CheckBox x:Name="FamilyEligibleBox" Content="Family Inventory eligible" Margin="0,0,18,8"/>
                            <CheckBox x:Name="StorageMaidBox" Content="Storage maid available" Margin="0,0,18,8"/>
                            <CheckBox x:Name="TransactionMaidBox" Content="Transaction maid available" Margin="0,0,18,8"/>
                            <CheckBox x:Name="MagnusBox" Content="Magnus storage unlocked" Margin="0,0,18,8"/>
                        </WrapPanel>
                        <Button Style="{StaticResource SubtleButton}" Content="Build safest transfer steps" Click="OnTransfer" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="TransferSummary" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,12,0,6"/>
                        <ItemsControl x:Name="TransferSteps"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Margin="0,2"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Recent decisions" Style="{StaticResource H2}"/>
                        <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MinHeight="150" Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Verdict" Binding="{Binding Verdict}" Width="110"/>
                                <DataGridTextColumn Header="Binding" Binding="{Binding Binding}" Width="120"/>
                                <DataGridTextColumn Header="Time" Binding="{Binding When}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
