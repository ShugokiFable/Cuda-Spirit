<UserControl x:Class="CudaSpirit.App.Views.MarketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="920" HorizontalAlignment="Left">
            <TextBlock Text="Central Market &amp; Alerts" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="Live prices from the public Central Market data feed. Alerts notify you to act in-game - Cuda Spirit never buys or sells for you (that would be botting)."/>

            <!-- Lookup -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Price lookup" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Width="150" Margin="0,0,10,0">
                            <TextBlock Text="Item ID" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="ItemIdBox" Text="10005"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="0,0,10,0">
                            <TextBlock Text="Enhance (sid)" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="SidBox" Text="0"/>
                        </StackPanel>
                        <Button Style="{StaticResource GlowButton}" Content="Look up" Click="OnLookup" VerticalAlignment="Bottom"/>
                    </WrapPanel>
                    <Border x:Name="ResultCard" Background="{DynamicResource BgPanelHiBrush}" CornerRadius="4" Padding="14" Margin="0,12,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="ResultName" FontWeight="SemiBold" FontSize="15"/>
                            <TextBlock x:Name="ResultPrice" Foreground="{DynamicResource EmberBrush}" FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock x:Name="ResultMeta" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Alert at ≤" VerticalAlignment="Center" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="AlertPriceBox" Width="140" Margin="8,0"/>
                                <Button Style="{StaticResource GlowButton}" Content="Add alert" Click="OnAddAlert"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusText" Style="{StaticResource Muted}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Alerts -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Price alerts" Style="{StaticResource H2}"/>
                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource GlowButton}"
                                Content="Check now" Click="OnCheckAlerts"/>
                    </DockPanel>
                    <ItemsControl x:Name="AlertList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPanelHiBrush}" CornerRadius="4" Padding="12,8" Margin="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Sub}" Style="{StaticResource Muted}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding State}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Grid.Column="2" Content="✕" Tag="{Binding Id}" Click="OnDeleteAlert"
                                                Background="Transparent" Foreground="{DynamicResource CrimsonBrush}"
                                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
