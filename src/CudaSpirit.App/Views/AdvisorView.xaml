<UserControl x:Class="CudaSpirit.App.Views.AdvisorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:CudaSpirit.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" x:Name="VisionBtn" Style="{StaticResource GlowButton}"
                    Content="👁 Read screen" Click="OnVision" VerticalAlignment="Top"
                    ToolTip="Send a screenshot to the vision model (e.g. your gear/crystal screen)"/>
            <StackPanel>
                <TextBlock Text="AI Advisor" Style="{StaticResource H1}"/>
                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,2,0,0"
                           Text="The Black Spirit sees your live build before every reply. This chat is synced with the movable Advisor Overlay."/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14">
            <v:AdvisorChat/>
        </Border>
    </Grid>
</UserControl>
