<UserControl x:Class="CudaSpirit.App.Views.PearlShopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Pearl Shop Value Lab" Style="{StaticResource H1}"/>
                <TextBlock Text="Score offers by permanence, real discount, binding, randomness, free alternatives, duplication, and your budget." Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                <TextBlock x:Name="SpendShieldText" Style="{StaticResource Muted}" Margin="0,3,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource SubtleButton}" Content="Clear no-spend shield" Click="OnClearSpendShield" Margin="0,0,8,0"/>
                <Button Style="{StaticResource GlowButton}" Content="Sync current offers" Click="OnSync"/>
            </StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,12,16">
                        <StackPanel>
                            <TextBlock Text="Evaluate an offer" Style="{StaticResource H2}"/>
                            <TextBlock Text="Offer or bundle name" Style="{StaticResource Muted}" Margin="0,10,0,3"/>
                            <TextBox x:Name="OfferNameBox"/>
                            <TextBlock Text="Paste contents or description" Style="{StaticResource Muted}" Margin="0,10,0,3"/>
                            <TextBox x:Name="ContentsBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="76"
                                     ToolTip="Paste the exact included items. The evaluator scans for RNG, rerolls, subscriptions, consumable padding, binding, and duplicate utility."/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0"><TextBlock Text="Sale price (Pearls)" Style="{StaticResource Muted}"/><TextBox x:Name="PriceBox" Text="0"/></StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Original price (Pearls)" Style="{StaticResource Muted}"/><TextBox x:Name="OriginalPriceBox" Text="0"/></StackPanel>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0"><TextBlock Text="Hours until offer ends" Style="{StaticResource Muted}"/><TextBox x:Name="ExpiryHoursBox" Text="-1" ToolTip="Use -1 when unknown. A countdown never turns a bad offer into good value."/></StackPanel>
                                <TextBlock Grid.Column="1" Text="Unknown is safer than guessing. The configured cooling-off period is applied automatically." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="8,18,0,0"/>
                            </Grid>
                            <WrapPanel Margin="0,12,0,0">
                                <CheckBox x:Name="PermanentBox" Content="Permanent family-wide utility" Margin="0,0,16,8"/>
                                <CheckBox x:Name="RandomBox" Content="Random contents" Margin="0,0,16,8"/>
                                <CheckBox x:Name="CharacterBoundBox" Content="Character-bound/specific" Margin="0,0,16,8"/>
                                <CheckBox x:Name="FreeAlternativeBox" Content="Free/in-game alternative" Margin="0,0,16,8"/>
                                <CheckBox x:Name="DuplicateBox" Content="Already own equivalent" Margin="0,0,16,8"/>
                                <CheckBox x:Name="PaddingBox" Content="Mostly consumables / bundle padding" Margin="0,0,16,8"/>
                                <CheckBox x:Name="BuyAllBox" Content="I would buy every included item separately" Margin="0,0,16,8"/>
                            </WrapPanel>
                            <Button Style="{StaticResource GlowButton}" Content="Score this purchase" Click="OnEvaluate" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="ScoreText" Text="Not evaluated" FontSize="24" FontWeight="Bold"/>
                            <TextBlock x:Name="VerdictText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <TextBlock x:Name="SummaryText" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <TextBlock Text="Good signals" Style="{StaticResource H2}"/>
                            <ItemsControl x:Name="PositivesList" Margin="0,5,0,12"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=+ {0}}" TextWrapping="Wrap" Margin="0,2"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                            <TextBlock Text="Warnings" Style="{StaticResource H2}"/>
                            <ItemsControl x:Name="WarningsList" Margin="0,5,0,0"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=! {0}}" TextWrapping="Wrap" Margin="0,2"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,12,16">
                        <StackPanel>
                            <TextBlock Text="Current official Pearl Shop notices" Style="{StaticResource H2}"/>
                            <ListBox x:Name="OffersList" Margin="0,10,0,0" MinHeight="300" MouseDoubleClick="OnOpenOffer">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Meta}" Style="{StaticResource Muted}" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,3,0,0" MaxHeight="70"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Style="{StaticResource SubtleButton}" Content="Ask advisor about selected notice" Click="OnAskSelected"/>
                            </StackPanel>
                            <TextBlock Text="Double-click a notice to inspect the official contents and sale period." Style="{StaticResource Muted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Default buying order" Style="{StaticResource H2}"/>
                            <TextBlock Text="1. Permanent family-wide utility that fixes real friction.&#x0a;2. Character slots / maids / infrastructure when discounted and needed.&#x0a;3. Character-bound weight or inventory only for a confirmed long-term main.&#x0a;4. Cosmetics you knowingly value.&#x0a;5. Temporary buffs and consumables only with a concrete cost comparison.&#x0a;6. RNG boxes and reroll sinks: usually skip." TextWrapping="Wrap" Margin="0,10,0,16"/>
                            <TextBlock Text="Hard skips by default" Style="{StaticResource H2}"/>
                            <TextBlock Text="• Random boxes valued by jackpot.&#x0a;• Full-price consumable enhancement bundles.&#x0a;• Duplicate pets/maids without a plan.&#x0a;• Weight or inventory on an undecided alt.&#x0a;• Reroll items without a hard attempt cap.&#x0a;• Temporary buffs during inactive weeks." TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock x:Name="StatusText" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
