<UserControl x:Class="CudaSpirit.App.Views.BossesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Bosses &amp; Events" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="Weekly world/field boss timetable in your local time. Edit the schedule in BossScheduleService to match your exact server."/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BossList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,10" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="8" CornerRadius="4" Margin="0,0,14,0"
                                        Background="{Binding Accent}"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource H2}"/>
                                    <TextBlock Text="{Binding Sub}" Style="{StaticResource Muted}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Countdown}" FontSize="20" FontWeight="Bold"
                                               Foreground="{Binding Accent}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding When}" Style="{StaticResource Muted}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
