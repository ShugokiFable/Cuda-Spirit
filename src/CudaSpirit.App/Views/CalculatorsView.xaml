<UserControl x:Class="CudaSpirit.App.Views.CalculatorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Calculators" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="Native BDO calculators - no web page, real math. (Enhancement cost lives on the Enhancement tab. Caphras &amp; crystal presets coming next.)"/>

            <!-- Marketplace tax -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="💰 Marketplace Tax" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,10"
                               Text="What you actually pocket after Central Market tax, with the usual Value Pack / Merchant Ring / Family Fame bonuses."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sale price (silver)" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="PriceBox" Text="100000000" Margin="0,3,0,10" TextChanged="OnTaxChanged"/>
                            <TextBlock Text="Bonuses" Style="{StaticResource Muted}"/>
                            <ComboBox x:Name="TaxTierBox" Margin="0,3,0,0" SelectionChanged="OnTaxChanged"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{DynamicResource BgPanelHiBrush}" CornerRadius="4" Padding="14" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="You receive" Style="{StaticResource Muted}"/>
                                <TextBlock x:Name="NetText" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource EmberBrush}"/>
                                <TextBlock x:Name="TaxText" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cron source -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="🪙 Cron stone source" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,10"
                               Text="Cheapest way to get the crons you need: buy from the vendor (fixed 3M each) or merge outfits/artifacts. Enter how many you need."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Crons needed" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="CronNeedBox" Text="1000" Margin="0,3,0,10" TextChanged="OnCronChanged"/>
                            <TextBlock Text="Your merged-cron price each (silver)" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="MergePriceBox" Text="2185000" Margin="0,3,0,0" TextChanged="OnCronChanged"
                                     ToolTip="Outfit set (~1500 crons) ÷ its market cost. Blackstar/artifact merges differ."/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{DynamicResource BgPanelHiBrush}" CornerRadius="4" Padding="14" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock x:Name="VendorText" FontSize="14"/>
                                <TextBlock x:Name="MergeText" FontSize="14" Margin="0,4,0,0"/>
                                <Separator Margin="0,8" Background="#22FFFFFF"/>
                                <TextBlock x:Name="CronVerdict" TextWrapping="Wrap" Foreground="{DynamicResource EmberBrush}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
