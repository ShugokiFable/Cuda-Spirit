<UserControl x:Class="CudaSpirit.App.Views.EnhancementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Enhancement &amp; Failstack Planner" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="Estimates use a community-consensus rate model (PA doesn't publish exact odds). Great for comparing routes and expected cron cost - not a promise on any single tap."/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Inputs -->
                <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Setup" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                        <TextBlock Text="Item kind" Style="{StaticResource Muted}"/>
                        <ComboBox x:Name="KindBox" Margin="0,3,0,8" SelectionChanged="OnChanged"/>
                        <TextBlock Text="Current grade" Style="{StaticResource Muted}"/>
                        <ComboBox x:Name="CurrentBox" Margin="0,3,0,8" SelectionChanged="OnChanged"/>
                        <TextBlock Text="Target grade" Style="{StaticResource Muted}"/>
                        <ComboBox x:Name="TargetBox" Margin="0,3,0,8" SelectionChanged="OnChanged"/>
                        <TextBlock Text="Failstacks" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="StacksBox" Text="30" Margin="0,3,0,8" TextChanged="OnChanged"/>
                        <CheckBox x:Name="CronBox" Content="Use cron stones (no downgrade)" IsChecked="True"
                                  Foreground="{DynamicResource InkSoftBrush}" Margin="0,4" Click="OnChanged"/>
                        <TextBlock Text="Cron per tap (shown in-game)" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="CronCostBox" Text="1" Margin="0,3,0,8" TextChanged="OnChanged"/>
                        <TextBlock Text="Material cost / tap (silver)" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="MatCostBox" Text="0" Margin="0,3,0,8" TextChanged="OnChanged"
                                 ToolTip="Cost of the item + black stones/mats consumed per attempt (from the market)"/>
                        <TextBlock Text="Cron stone price (silver)" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="CronPriceBox" Text="2000000" Margin="0,3,0,0" TextChanged="OnChanged"
                                 ToolTip="Vendor crons ≈ 3,000,000 · merged crons are cheaper"/>
                    </StackPanel>
                </Border>

                <!-- Results -->
                <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Odds this tap" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="ChanceText" FontSize="46" FontWeight="Bold"
                                   Foreground="{DynamicResource EmberBrush}" Margin="0,2,0,2"/>
                        <TextBlock x:Name="RecStacksText" Style="{StaticResource Muted}"/>
                        <Separator Margin="0,12" Background="#22FFFFFF"/>
                        <TextBlock Text="To reach target (Monte-Carlo, 20k trials)" Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TapsText" FontSize="15"/>
                        <TextBlock x:Name="CronsText" FontSize="15" Margin="0,4,0,0"/>
                        <TextBlock x:Name="ConfText" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Silver cost -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Estimated silver cost to target" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TotalCostText" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource EmberBrush}"/>
                    <TextBlock x:Name="CostBreakdownText" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                    <Separator Margin="0,10" Background="#22FFFFFF"/>
                    <TextBlock Text="Cron vs no-cron" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="CronCompareText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Chance curve across failstacks -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Chance vs failstacks (current → +1)" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="CurveList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Height="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="4" HorizontalAlignment="Left"
                                            Width="{Binding BarWidth}" Height="14" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF7A1020" Offset="0"/>
                                                <GradientStop Color="#FFFF6A3D" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Pct}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
