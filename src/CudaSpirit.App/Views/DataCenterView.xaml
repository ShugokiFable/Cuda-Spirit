<UserControl x:Class="CudaSpirit.App.Views.DataCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
            <TextBlock Text="Live Data Center" Style="{StaticResource H1}"/>
            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,16"
                       Text="Versioned local knowledge database for official updates, regional market snapshots, optional BDO Alerts data, and read-only JSON extracted from your own client. Every record carries source and freshness metadata."/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="SyncButton" Style="{StaticResource GlowButton}" Content="↻ Sync live sources" Click="OnSync" Margin="0,0,8,0"/>
                            <Button Content="Import JSON folder" Click="OnImport"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Database health" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="StatsText" Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock x:Name="StatusText" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{DynamicResource InkSoftBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Source freshness" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                    <DataGrid x:Name="SourcesGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              HeadersVisibility="Column" MinHeight="130" MaxHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Source" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            <DataGridTextColumn Header="Last success" Binding="{Binding LastSuccess}" Width="2*"/>
                            <DataGridTextColumn Header="Records" Binding="{Binding Records}" Width="*"/>
                            <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Search advisor knowledge" Style="{StaticResource H2}"/>
                    <DockPanel Margin="0,10,0,10">
                        <Button DockPanel.Dock="Right" Content="Search" Click="OnSearch" Margin="8,0,0,0"/>
                        <TextBox x:Name="SearchBox" VerticalContentAlignment="Center" KeyDown="OnSearchKeyDown"
                                 ToolTip="Example: Deboreka enhancement, current market Caphras, latest class changes"/>
                    </DockPanel>
                    <ListBox x:Name="ResultsList" MinHeight="120" MaxHeight="340">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Meta}" Style="{StaticResource Muted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Summary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
